<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración de Precio</title>
    <link rel="stylesheet" href="/public/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .config-form {
            background-color: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            max-width: 400px;
            width: 100%;
            border: 1px solid #ddd;
        }
        
        .config-form label {
            display: block;
            margin-bottom: 15px;
            font-weight: bold;
            color: #333;
            text-align: left;
        }

        .config-form input[type="number"] {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 16px;
        }

        .btn-update {
            width: 100%;
            padding: 12px;
            background-color: rgb(0, 0, 128);
            color: white;
            border: none;
            border-radius: 5px;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        .btn-update:hover {
            background-color: rgb(11, 11, 255);
        }

        .current-price-box {
            background-color: #f2f2f2;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 20px;
            font-size: 18px;
            color: rgb(0, 0, 128);
            font-weight: bold;
        }

        /* Estilo para el badge de chat */
      .badge-unread {
    position: absolute;
    right: 8px;           /* Ajusta para que quede centrado en el padding-right */
    top: 50%;
    transform: translateY(-50%);
    background-color: red;
    color: white;
    border-radius: 50%;
    padding: 2px 6px;
    font-size: 0.75rem;
    min-width: 18px;
    text-align: center;
    box-sizing: border-box;
    margin-left: 0;       /* Anula cualquier margen izquierdo heredado */
}
    </style>
</head>
<body>
    <header>
        <div class="menu-icon">
            <div class="menu-icon-bar"></div>
            <div class="menu-icon-bar"></div>
            <div class="menu-icon-bar"></div>
        </div>                                              
        <nav class="nav-menu">
            <a href="/home">Inicio</a>                     
            <a href="/historial/cuentas">historial</a>
            <a href="/notas">notas</a>
            <!-- Enlace de chat con badge de notificaciones -->
            <a href="/chat/grupal" class="chat-link">
                chat
                <% if (typeof usuarioId !== 'undefined' && usuarioId) { %>
                    <span class="badge-unread" id="chatBadge" style="display: none;">0</span>
                <% } %>
            </a>
            <!-- El enlace a configuración ahora está disponible para todos los usuarios autenticados -->
            <a href="/configuracion" class="active">configuración</a>
            <% if (typeof usuarioRol !== 'undefined' && usuarioRol === 'admin') { %>
                <a href="/admin/invitaciones">Invitaciones</a>
            <% } %>                                                             
        </nav>                                                                         
        <div class="registroinicio">
            <% if (typeof nombreUsuario !== 'undefined' && nombreUsuario) { %>
                <span><%= nombreUsuario %></span>
                <a href="/logout">Cerrar sesión</a>
            <% } else { %>
                <a href="/login">Iniciar sesión</a>
                <a href="/registro">Crear cuenta</a>
            <% } %>
        </div>
    </header>

    <main class="main-container">
        <h1 class="main-title">Configurar Precio del Bidón</h1>
        
        <div class="config-form">
            <div class="current-price-box">
                Precio actual: $<%= precio %>
            </div>

            <!-- Cambiamos la acción a /configuracion (sin /admin) -->
            <form action="/configuracion" method="POST">
                <label for="precio_bidon">Nuevo precio:</label>
                <input type="number" id="precio_bidon" name="precio_bidon" step="0.01" min="0" placeholder="Ej: 5000" required>
                                                                                                                                        
                <button type="submit" class="btn-update">
                    <i class="fas fa-save"></i> Actualizar Precio
                </button>
            </form>
        </div>
        
        <br>
        <a href="/home" style="color: rgb(0, 0, 128); text-decoration: none; font-weight: bold;">
            <i class="fas fa-arrow-left"></i> Volver al inicio
        </a>
    </main>

    <script>
        const menuIcon = document.querySelector('.menu-icon');
        const navMenu = document.querySelector('.nav-menu');
        const mainContainer = document.querySelector('.main-container');

        menuIcon.addEventListener('click', () => {
            navMenu.classList.toggle('show');
            if(navMenu.classList.contains('show')) {
                mainContainer.style.marginTop = '100px';
            } else {
                mainContainer.style.marginTop = '0px';
            }                                                          
        });
    </script>

    <!-- Script para el badge de chat (Socket.IO) -->
    <script src="/socket.io/socket.io.js"></script>
    <% if (typeof usuarioId !== 'undefined' && usuarioId) { %>
    <script>
        (function() {
            const socket = io();
            const usuarioId = <%= usuarioId %>;

            async function actualizarBadgeHeader() {
                try {
                    const response = await fetch('/api/no-leidos');
                    const noLeidosMap = await response.json();
                    const total = Object.values(noLeidosMap).reduce((acc, val) => acc + val, 0);
                    const badge = document.getElementById('chatBadge');
                    if (total > 0) {
                        badge.textContent = total;
                        badge.style.display = 'inline';
                    } else {
                        badge.style.display = 'none';
                    }
                } catch (error) {
                    console.error('Error al obtener no leídos:', error);
                }
            }

            socket.on('update-unread', actualizarBadgeHeader);
            document.addEventListener('DOMContentLoaded', actualizarBadgeHeader);
        })();
    </script>
    <% } %>
</body>
</html>