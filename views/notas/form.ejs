<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= nota ? 'Editar Nota' : 'Nueva Nota' %></title>
    <link rel="stylesheet" href="/public/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ===== ESTILOS MODERNOS PARA FORMULARIO DE NOTAS ===== */
        /* Misma paleta y estilo que detalleclientes.css */
        :root {
            --primary: #1e40af;
            --primary-light: #3b82f6;
            --primary-dark: #1e3a8a;
            --secondary: #10b981;
            --danger: #ef4444;
            --danger-light: #fecaca;
            --warning: #f59e0b;
            --info: #0ea5e9;
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --bg-hover: #f1f5f9;
            --text-primary: #0f172a;
            --text-secondary: #64748b;
            --text-light: #94a3b8;
            --border-color: #e2e8f0;
            --border-light: #f1f5f9;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Contenedor del formulario */
        .form-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Botón volver */
        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 20px;
            transition: var(--transition);
            padding: 8px 16px;
            border-radius: 30px;
            background: var(--bg-hover);
        }
        .btn-back:hover {
            background: var(--primary);
            color: white;
            transform: translateX(-4px);
        }

        /* Tarjeta del formulario */
        .form-card {
            background: var(--bg-card);
            border-radius: 24px;
            padding: 32px;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border-light);
            animation: slideInUp 0.4s ease-out;
        }

        /* Cabecera de la tarjeta */
        .card-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 2px solid var(--border-light);
        }
        .card-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: white;
            flex-shrink: 0;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            box-shadow: var(--shadow-sm);
        }
        .card-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0 0 4px;
        }
        .card-subtitle {
            font-size: 0.95rem;
            color: var(--text-secondary);
            margin: 0;
        }

        /* Alertas */
        .alert {
            padding: 14px 18px;
            border-radius: 12px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.95rem;
        }
        .alert-error {
            background: var(--danger-light);
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        /* Formulario moderno */
        .form-modern {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .form-group label {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        .form-group input[type="text"],
        .form-group textarea,
        .form-group input[type="file"] {
            padding: 14px 18px;
            border: 2px solid var(--border-color);
            border-radius: 14px;
            font-size: 1rem;
            font-family: inherit;
            color: var(--text-primary);
            background: var(--bg-main);
            transition: var(--transition);
        }
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary);
            background: var(--bg-card);
            box-shadow: 0 0 0 4px rgba(30, 64, 175, 0.1);
        }
        .form-group textarea {
            resize: vertical;
            min-height: 150px;
        }
        .help-text {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 4px;
        }

        /* Checkbox grupo */
        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .checkbox-group label {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            font-weight: 600;
            text-transform: none;
            font-size: 1rem;
        }
        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            accent-color: var(--primary);
        }

        /* Acciones del formulario */
        .form-actions {
            display: flex;
            gap: 16px;
            margin-top: 32px;
        }
        .form-actions .btn {
            flex: 1;
            padding: 16px;
            font-size: 1.1rem;
            border-radius: 14px;
        }
        .btn-secondary {
            background: var(--bg-hover);
            color: var(--primary);
            border: 2px solid var(--primary);
        }
        .btn-secondary:hover {
            background: var(--primary);
            color: white;
        }

        /* Botón primario (heredado de index) */
        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            border: none;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        /* Animación */
        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .form-container {
                padding: 16px;
            }
            .form-card {
                padding: 24px;
            }
            .card-title {
                font-size: 1.4rem;
            }
            .card-icon {
                width: 48px;
                height: 48px;
                font-size: 1.5rem;
            }
            .form-actions {
                flex-direction: column;
            }
        }

        @media (max-width: 480px) {
            .form-card {
                padding: 20px;
            }
            .card-header {
                gap: 12px;
            }
            .card-title {
                font-size: 1.2rem;
            }
            .card-subtitle {
                font-size: 0.85rem;
            }
            .form-group input,
            .form-group textarea {
                padding: 12px 14px;
            }
        }
    </style>
</head>
<body>
    <header>
        <div class="menu-icon">
            <div class="menu-icon-bar"></div>
            <div class="menu-icon-bar"></div>
            <div class="menu-icon-bar"></div>
        </div>
        <nav class="nav-menu">
            <a href="/home">Inicio</a>
            <a href="/historial/cuentas">Historial</a>
            <a href="/notas">Notas</a>
            <% if (usuarioRol === 'admin') { %>
                <a href="/admin/invitaciones" class="admin-link">Invitaciones</a>
                <a href="/admin/configuracion" class="admin-link">Configuración</a>
            <% } %>
        </nav>
        <div class="registroinicio">
            <% if (nombreUsuario) { %>
                <span><%= nombreUsuario %></span>
                <a href="/logout">Cerrar sesión</a>
            <% } %>
        </div>
    </header>

    <main class="main-container form-container">
        <a href="/notas" class="btn-back">
            <i class="fas fa-arrow-left"></i> Volver a Notas
        </a>

        <div class="card form-card">
            <div class="card-header">
                <div class="card-icon">
                    <i class="fas fa-<%= nota ? 'edit' : 'plus' %>"></i>
                </div>
                <div>
                    <h2 class="card-title"><%= nota ? 'Editar Nota' : 'Crear Nueva Nota' %></h2>
                    <p class="card-subtitle">Completa los campos</p>
                </div>
            </div>

            <% if (typeof error !== 'undefined') { %>
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i> <%= error %>
                </div>
            <% } %>

            <form action="<%= nota ? '/notas/' + nota.id : '/notas' %>" method="POST" enctype="multipart/form-data" class="form-modern">
                <div class="form-group">
                    <label for="titulo">Título</label>
                    <input type="text" id="titulo" name="titulo" value="<%= nota ? nota.titulo : '' %>" required placeholder="Título de la nota">
                </div>

                <div class="form-group">
                    <label for="contenido">Contenido</label>
                    <textarea id="contenido" name="contenido" rows="6" required placeholder="Escribe tu nota aquí..."><%= nota ? nota.contenido : '' %></textarea>
                </div>

                <div class="form-group">
                    <label for="archivos">Adjuntar archivos (opcional, máximo 10)</label>
                    <input type="file" id="archivos" name="archivos" multiple accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt">
                    <small class="help-text">Puedes seleccionar múltiples archivos. Tamaño máximo por archivo: 50MB. Formatos permitidos: imágenes, videos, PDF, Word, Excel, PowerPoint, texto. En edición, si subes nuevos archivos se reemplazarán todos los anteriores.</small>
                </div>

                <div class="form-group checkbox-group">
                    <label>
                        <input type="checkbox" name="compartida" <%= nota && nota.compartida ? 'checked' : '' %>>
                        <span>Compartir esta nota con todos los usuarios</span>
                    </label>
                    <small class="help-text">Si activas esta opción, otros usuarios podrán verla (el administrador también podrá editarla/eliminarla).</small>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> <%= nota ? 'Actualizar' : 'Guardar' %>
                    </button>
                    <a href="/notas" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>

    <script>
        const menuIcon = document.querySelector('.menu-icon');
        const navMenu = document.querySelector('.nav-menu');
        const mainContainer = document.querySelector('.main-container');

        menuIcon.addEventListener('click', () => {
            navMenu.classList.toggle('show');
            if (navMenu.classList.contains('show')) {
                mainContainer.style.marginTop = '250px';
            } else {
                mainContainer.style.marginTop = '0';
            }
        });
    </script>
</body>
</html>