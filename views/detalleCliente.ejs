<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalle - <%= cliente.nombre %></title>
    <link rel="stylesheet" href="/public/css/detallecliente.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Estilos adicionales para el modal con pestañas */
        .payment-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 10px;
        }
        .payment-tab {
            flex: 1;
            text-align: center;
            padding: 10px;
            cursor: pointer;
            border-radius: 8px 8px 0 0;
            background: var(--bg-secondary);
            transition: all 0.3s;
            font-weight: 500;
        }
        .payment-tab.active {
            background: var(--primary);
            color: white;
        }
        .payment-tab-content {
            display: none;
        }
        .payment-tab-content.active {
            display: block;
        }
        .input-group {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .input-group input {
            flex: 1;
        }
        .input-group span {
            font-size: 1.2rem;
            font-weight: bold;
            color: var(--text-primary);
        }

        /* Estilos exclusivos para badges del historial semanal */
        .semana-badge-success {
            background-color: #28a745;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
        }
        .semana-badge-danger {
            background-color: #dc3545;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
        }
        .semana-badge-secondary {
            background-color: #6c757d;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
        }
        .btn-delete {
            background: none;
            border: none;
            color: #dc3545;
            cursor: pointer;
            font-size: 1.2rem;
        }

        /* ===== ESTILOS GENERALES DE TABLA ===== */
        .table-modern td,
        .table-modern th {
            font-size: 1rem;
            padding: 12px 8px;
            vertical-align: middle;
        }

        .table-modern th {
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .table-modern td,
            .table-modern th {
                font-size: 0.9rem;
                padding: 10px 6px;
            }
        }

        /* Badges y fechas heredan tamaño por defecto */
        .table-modern td .badge,
        .table-modern td .date-cell,
        .table-modern td .qty-badge,
        .table-modern td .price-display {
            font-size: inherit; /* Hereda el tamaño del td */
        }

        /* ===== ESTILOS ESPECÍFICOS PARA GABRIEL ===== */
        body.gabriel .table-modern td,
        body.gabriel .table-modern th {
            font-size: 1.4rem;  /* Celdas y encabezados más grandes */
        }

        /* Excepción: los botones de acción mantienen su tamaño original */
        body.gabriel .table-modern td .btn-payment,
        body.gabriel .table-modern td .btn-delete {
            font-size: 0.9rem;   /* Para btn-payment */
        }
        body.gabriel .table-modern td .btn-delete {
            font-size: 1.2rem;   /* Para el icono eliminar */
        }

        /* Ajuste responsive para gabriel */
        @media (max-width: 768px) {
            body.gabriel .table-modern td,
            body.gabriel .table-modern th {
                font-size: 1.2rem;
            }
        }

        /* ===== ESTILOS PARA BOTONES DE PAGO ===== */
        .btn-payment,
        .btn-complete,
        .btn-partial {
            color: white !important;
        }

        .payment-group {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .btn-payment {
            background: var(--primary);
            border: none;
            border-radius: 20px;
            padding: 6px 12px;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-payment:hover {
            filter: brightness(1.1);
        }

        .btn-complete {
            background: #28a745;
        }

        .btn-partial {
            background: #ffc107;
        }

        .btn-delete {
            background: transparent;
            border: none;
            color: #dc3545;
            font-size: 1.2rem;
            margin-left: 8px;
            transition: color 0.2s;
        }

        .btn-delete:hover {
            color: #b02a37;
        }

        @media (max-width: 480px) {
            .payment-group {
                flex-direction: column;
                align-items: flex-start;
            }
            .btn-payment {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<!-- Clase condicional según el rol del usuario -->
<body class="<%= usuarioRol %>">
    <!-- Header -->
    <header class="header">
        <div class="container">
            <a href="/home<%= dia ? '?dia=' + dia : '' %>" class="header-back">
                <i class="fas fa-arrow-left"></i>
                <span>Volver</span>
            </a>
            <div class="header-title">
                <i class="fas fa-user-circle"></i>
                <div>
                    <h1><%= cliente.nombre %></h1>
                    <p class="header-subtitle">Gestión de ventas y envases</p>
                </div>
            </div>
        </div>
    </header>

    <main class="container main-content">
        <!-- Tarjeta de Información del Cliente -->
        <div class="info-card">
            <div class="info-stat">
                <span class="stat-label">Bidones en Poder</span>
                <span class="stat-value highlight-blue">
                    <% 
                        let bidonesVal = Number(cliente.bidones_adeudados);
                        let bidonesMostrar = bidonesVal % 1 === 0 ? bidonesVal.toString() : bidonesVal.toFixed(2).replace(/\.?0+$/, '').replace('.', ',');
                    %>
                    <%= bidonesMostrar %>
                </span>
            </div>
            <div class="info-stat">
                <span class="stat-label">Precio Unitario</span>
                <span class="stat-value">
                    <% 
                        let precioVal = Number(precioActual);
                        let precioMostrar = precioVal % 1 === 0 ? precioVal.toString() : precioVal.toFixed(2).replace(/\.?0+$/, '').replace('.', ',');
                    %>
                    $<%= precioMostrar %>
                </span>
            </div>
        </div>

        <!-- Sección: Nueva Venta -->
        <section class="card">
            <div class="card-header">
                <div class="card-icon primary">
                    <i class="fas fa-plus"></i>
                </div>
                <div>
                    <h2 class="card-title">Nueva Venta</h2>
                    <p class="card-subtitle">Registra una nueva transacción</p>
                </div>
            </div>

            <form class="form-modern" action="/clientes/<%= cliente.id %>/cuentas" method="POST">
                <div class="form-row">
                    <div class="form-group">
                        <label for="estado_pago">Estado de Pago</label>
                        <div class="select-wrapper">
                            <select id="estado_pago" name="estado_pago" required>
                                <option value="1">✓ Pagado</option>
                                <option value="0">⏳ Fiado</option>
                                <option value="2">↻ Transferencia</option>
                            </select>
                        </div>
                    </div>

                    <% if (usuarioRol === 'gabriel') { %>
                        <div style="width: 100%;">
                            <div class="payment-tabs" style="margin-top: 10px;">
                                <div class="payment-tab active" onclick="switchVentaTab('cantidad')">Por Cantidad</div>
                                <div class="payment-tab" onclick="switchVentaTab('monto')">Por Monto</div>
                            </div>
                            <div id="venta-tab-cantidad" class="payment-tab-content active">
                                <div class="form-group">
                                    <label for="cantidad_bidones">Cantidad de Bidones</label>
                                    <input type="number" id="cantidad_bidones" name="cantidad_bidones" min="1" max="999" step="1" placeholder="Ej: 5">
                                </div>
                            </div>
                            <div id="venta-tab-monto" class="payment-tab-content">
                                <div class="form-group">
                                    <label for="monto">Monto ($)</label>
                                    <input type="number" id="monto" name="monto" min="0.01" step="0.01" placeholder="Ej: 5000">
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="form-group">
                            <label for="cantidad_bidones">Cantidad de Bidones</label>
                            <input type="number" id="cantidad_bidones" name="cantidad_bidones" min="1" max="999" required placeholder="Ingresa cantidad">
                        </div>
                    <% } %>
                </div>

                <% if (usuarioRol === 'gabriel') { %>
                    <div class="form-summary" id="gabriel-summary" style="display: none;">
                        <div class="summary-item">
                            <span>Total:</span>
                            <strong class="total-price">$0</strong>
                        </div>
                    </div>
                <% } else { %>
                    <div class="form-summary">
                        <div class="summary-item">
                            <span>Precio unitario:</span>
                            <strong>$<%= precioMostrar %></strong>
                        </div>
                        <div class="summary-total">
                            <span>Total:</span>
                            <strong class="total-price">$0</strong>
                        </div>
                    </div>
                <% } %>

                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-check-circle"></i>
                    Registrar Venta
                </button>
            </form>
        </section>

        <!-- Sección: Historial de Movimientos -->
        <section class="card">
            <div class="card-header">
                <div class="card-icon info">
                    <i class="fas fa-history"></i>
                </div>
                <div>
                    <h2 class="card-title">Historial de Movimientos</h2>
                    <p class="card-subtitle"><%= cuentas ? cuentas.length : 0 %> registros</p>
                </div>
            </div>

            <% if (cuentas && cuentas.length > 0) { %>
                <div class="table-wrapper">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th>Estado</th>
                                <% if (usuarioRol === 'gabriel') { %>
                                    <th>Monto</th>
                                <% } else { %>
                                    <th>Cantidad</th>
                                    <th>Total</th>
                                <% } %>
                                <th>Fecha</th>
                                <th class="text-center">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cuentas.forEach((cuenta, index) => { 
                                const cantidadFormateada = (() => {
                                    let num = Number(cuenta.cantidad_bidones);
                                    if (num % 1 === 0) return num.toString();
                                    return num.toFixed(2).replace(/\.?0+$/, '').replace('.', ',');
                                })();
                                const totalFormateado = Number(cuenta.total).toFixed(2).replace('.', ',');
                            %>
                                <tr class="table-row-hover">
                                    <td data-label="Estado">
                                        <% if (cuenta.estado_pago == 1) { %>
                                            <span class="badge badge-success">
                                                <i class="fas fa-check"></i> Pagado
                                            </span>
                                        <% } else if (cuenta.estado_pago == 2) { %>
                                            <span class="badge badge-transfer">
                                                <i class="fas fa-exchange-alt"></i> Transferencia
                                            </span>
                                        <% } else { %>
                                            <span class="badge badge-pending">
                                                <i class="fas fa-clock"></i> Fiado
                                            </span>
                                        <% } %>
                                    </td>
                                    <% if (usuarioRol === 'gabriel') { %>
                                        <td data-label="Monto">
                                            <span class="price-display">$<%= totalFormateado %></span>
                                        </td>
                                    <% } else { %>
                                        <td data-label="Cantidad">
                                            <span class="qty-badge"><%= cantidadFormateada %> u.</span>
                                        </td>
                                        <td data-label="Total">
                                            <span class="price-display">$<%= totalFormateado %></span>
                                        </td>
                                    <% } %>
                                    <td data-label="Fecha">
                                        <span class="date-cell">
                                            <%= new Date(cuenta.fecha_publicacion).toLocaleDateString('es-AR', { 
                                                day: '2-digit', 
                                                month: '2-digit',
                                                year: '2-digit'
                                            }) %>
                                        </span>
                                    </td>
                                    <td class="text-center action-cell">
                                        <div class="action-buttons">
                                            <% if (cuenta.estado_pago == 0) { %>
                                                <div class="payment-group">
                                                    <form action="/clientes/<%= cliente.id %>/cuentas/<%= cuenta.id %>/actualizarEstadoPago" method="POST" style="display: inline;" onsubmit="return confirm('¿Marcar como pagado?')">
                                                        <input type="hidden" name="estado_pago" value="1">
                                                        <button type="submit" class="btn-payment btn-complete" title="Pago completo">
                                                            <i class="fas fa-check-circle"></i>   
                                                            <span class="btn-text">Pago completo</span>
                                                        </button>
                                                    </form>
                                                    
                                                    <button type="button" class="btn-payment btn-partial" title="Pago parcial" 
                                                        onclick="openPartialPaymentModal(<%= cuenta.id %>, <%= cliente.id %>, <%= cuenta.cantidad_bidones %>, <%= cuenta.precio_bidon %>)">
                                                        <i class="fas fa-coins"></i>
                                                        <span class="btn-text">Parcial</span>
                                                    </button>
                                                </div>
                                            <% } %>
                                            
                                            <form action="/clientes/<%= cliente.id %>/cuentas/<%= cuenta.id %>/eliminar" method="POST" style="display: inline;" onsubmit="return confirm('¿Eliminar este registro?')">
                                                <button type="submit" class="btn-delete" title="Eliminar">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <!-- Paginador -->
                <div class="pagination-container">
                    <% if (paginaActual > 1) { %>
                        <a href="/clientes/<%= cliente.id %>?pagina=<%= paginaActual - 1 %><%= dia ? '&dia=' + dia : '' %>" class="btn-pagination btn-prev">
                            <i class="fas fa-chevron-left"></i> Atrás
                        </a>
                    <% } else { %>
                        <button class="btn-pagination btn-prev" disabled>
                            <i class="fas fa-chevron-left"></i> Atrás
                        </button>
                    <% } %>

                    <div class="pagination-info">
                        <span>Página <strong><%= paginaActual %></strong> de <strong><%= totalPaginas %></strong></span>
                        <small>(<%= totalCuentas %> registros totales)</small>
                    </div>

                    <% if (paginaActual < totalPaginas) { %>
                        <a href="/clientes/<%= cliente.id %>?pagina=<%= paginaActual + 1 %><%= dia ? '&dia=' + dia : '' %>" class="btn-pagination btn-next">
                            Siguiente <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } else { %>
                        <button class="btn-pagination btn-next" disabled>
                            Siguiente <i class="fas fa-chevron-right"></i>
                        </button>
                    <% } %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>No hay registros de ventas aún</p>
                    <span>Comienza a registrar transacciones para verlas aquí</span>
                </div>
            <% } %>
        </section>

        <!-- Sección: Control de Envases -->
        <section class="card card-accent">
            <div class="card-header">
                <div class="card-icon warning">
                    <i class="fas fa-box"></i>
                </div>
                <div>
                    <h2 class="card-title">Control de Envases</h2>
                    <p class="card-subtitle">Gestión de bidones en poder del cliente</p>
                </div>
            </div>

            <div class="envases-container">
                <div class="envases-status">
                    <span class="status-label">Estado Actual</span>
                    <div class="status-main">
                        <i class="fas fa-wine-bottle"></i>
                        <span class="counter-value" id="displayActual">
                            <% 
                                let bidonesVal2 = Number(cliente.bidones_adeudados);
                                let bidonesMostrar2 = bidonesVal2 % 1 === 0 ? bidonesVal2.toString() : bidonesVal2.toFixed(2).replace(/\.?0+$/, '').replace('.', ',');
                            %>
                            <%= bidonesMostrar2 %>
                        </span>
                        <span class="status-unit">Bidones</span>
                    </div>
                </div>

                <form id="formUpdateBidones" action="/clientes/<%= cliente.id %>/actualizar-bidones" method="POST" class="form-stepper-container">
                    <label class="stepper-label">Ajustar Cantidad</label>
                    <div class="stepper-wrapper">
                        <button type="button" class="stepper-btn" onclick="adjustValue(-1)">
                            <i class="fas fa-minus"></i>
                        </button>                                               
                        <input type="number" name="bidonesAdeudados" id="inputBidones" value="<%= cliente.bidones_adeudados %>" min="0" max="999" step="0.01" required readonly>
                        <button type="button" class="stepper-btn" onclick="adjustValue(1)">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>

                    <button type="button" class="btn btn-primary btn-update-modern" onclick="confirmarActualizacion()">
                        <i class="fas fa-save"></i>
                        Guardar Cambios
                    </button>
                </form>
            </div>
        </section>

        <!-- Sección: Historial Semanal (solo para gabriel) -->
        <% if (usuarioRol === 'gabriel') { %>
        <section class="card">
            <div class="card-header">
                <div class="card-icon info">
                    <i class="fas fa-calendar-week"></i>
                </div>
                <div>
                    <h2 class="card-title">Historial Semanal</h2>
                    <p class="card-subtitle">Registro de compras por semana</p>
                </div>
            </div>

            <% if (historialSemanal && historialSemanal.length > 0) { %>
                <div class="table-wrapper">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th>Semana</th>
                                <th>Estado</th>
                                <th class="text-center">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% historialSemanal.forEach(item => { %>
                                <tr>
                                    <td data-label="Semana"><%= item.semanaFormateada %></td>
                                    <td data-label="Estado">
                                        <% if (item.estado === 'compro') { %>
                                            <span class="semana-badge-success"><i class="fas fa-check"></i> Compró</span>
                                        <% } else if (item.estado === 'no_compro') { %>
                                            <span class="semana-badge-danger"><i class="fas fa-times"></i> No compró</span>
                                        <% } else { %>
                                            <span class="semana-badge-secondary"><i class="fas fa-ban"></i> No estaba</span>
                                        <% } %>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn-delete" onclick="eliminarEstadoSemanal(<%= item.id %>, '<%= item.estado %>')" title="Eliminar">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-calendar-week"></i>
                    <p>No hay registros semanales</p>
                    <span>Los estados aparecerán aquí cuando los marques desde el inicio</span>
                </div>
            <% } %>
        </section>
        <% } %>

        <!-- Modal Pago Parcial -->
        <div id="partialPaymentModal" class="modal-overlay" style="display: none;">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>Registrar Pago Parcial</h3>
                    <button type="button" class="modal-close" onclick="closePartialPaymentModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="payment-info">
                        <div class="info-row">
                            <span class="info-label">Total de la cuenta:</span>
                            <span class="info-value">$<span id="totalAmount">0</span></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Bidones:</span>
                            <span class="info-value"><span id="originalQty">0</span> u. a $<span id="unitPrice"></span> c/u</span>
                        </div>
                    </div>

                    <div class="payment-tabs">
                        <div class="payment-tab active" onclick="switchPaymentTab('cantidad')">Por Cantidad</div>
                        <div class="payment-tab" onclick="switchPaymentTab('monto')">Por Monto</div>
                    </div>

                    <form id="partialPaymentForm" method="POST">
                        <div id="tab-cantidad" class="payment-tab-content active">
                            <div class="form-group">
                                <label for="cantidadPagada">Cantidad de bidones a pagar</label>
                                <div class="input-group">
                                    <input type="number" id="cantidadPagada" min="0.01" step="0.01" placeholder="Ej: 2,5" class="form-control">
                                    <span>u.</span>
                                </div>
                                <small class="input-hint">Equivale a $<span id="montoCalculado">0</span></small>
                            </div>
                        </div>

                        <div id="tab-monto" class="payment-tab-content">
                            <div class="form-group">
                                <label for="montoPagado">Monto a pagar ($)</label>
                                <input type="number" id="montoPagado" min="0.01" step="0.01" placeholder="Ej: 6000" class="form-control">
                                <small class="input-hint">Ingresa el monto en pesos</small>
                            </div>
                        </div>

                        <input type="hidden" id="montoFinal" name="monto_pagado">

                        <div class="payment-breakdown">
                            <div class="breakdown-row">
                                <span>Pagado:</span>
                                <strong>$<span id="paidAmount">0</span></strong>
                            </div>
                            <div class="breakdown-row">
                                <span>Resta:</span>
                                <strong class="remaining">$<span id="remainingAmount">0</span></strong>
                            </div>
                        </div>

                        <div class="modal-actions">
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-check"></i>
                                Confirmar Pago
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Funciones para el modal de pago parcial
        function formatearMonto(valor) {
            return valor.toFixed(2).replace('.', ',');
        }

        function formatearBidones(valor) {
            let num = Number(valor);
            if (isNaN(num)) return '0';
            if (num % 1 === 0) {
                return num.toString();
            } else {
                return num.toFixed(2).replace(/\.?0+$/, '').replace('.', ',');
            }
        }

        let currentCuentaId = null;
        let currentClienteId = null;

        const modal = document.getElementById('partialPaymentModal');
        const tabCantidad = document.getElementById('tab-cantidad');
        const tabMonto = document.getElementById('tab-monto');
        const inputCantidad = document.getElementById('cantidadPagada');
        const inputMonto = document.getElementById('montoPagado');
        const montoCalculadoSpan = document.getElementById('montoCalculado');
        const paidAmountSpan = document.getElementById('paidAmount');
        const remainingSpan = document.getElementById('remainingAmount');
        const montoFinalInput = document.getElementById('montoFinal');
        const totalAmountSpan = document.getElementById('totalAmount');
        const originalQtySpan = document.getElementById('originalQty');
        const unitPriceSpan = document.getElementById('unitPrice');

        function openPartialPaymentModal(cuentaId, clienteId, cantidad, precio) {
            currentCuentaId = cuentaId;
            currentClienteId = clienteId;

            originalQtySpan.textContent = formatearBidones(cantidad);
            unitPriceSpan.textContent = formatearBidones(precio);
            let total = cantidad * precio;
            totalAmountSpan.textContent = formatearMonto(total);

            inputCantidad.value = '';
            inputMonto.value = '';
            montoCalculadoSpan.textContent = '0,00';
            paidAmountSpan.textContent = '0,00';
            remainingSpan.textContent = formatearMonto(total);
            montoFinalInput.value = '';

            switchPaymentTab('cantidad');
            modal.style.display = 'flex';
        }

        function closePartialPaymentModal() {
            modal.style.display = 'none';
        }

        function switchPaymentTab(tab) {
            document.querySelectorAll('.payment-tab').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.payment-tab-content').forEach(el => el.classList.remove('active'));
            
            if (tab === 'cantidad') {
                document.querySelectorAll('.payment-tab')[0].classList.add('active');
                tabCantidad.classList.add('active');
                inputCantidad.focus();
                actualizarDesdeCantidad();
            } else {
                document.querySelectorAll('.payment-tab')[1].classList.add('active');
                tabMonto.classList.add('active');
                inputMonto.focus();
                actualizarDesdeMonto();
            }
        }

        inputCantidad.addEventListener('input', actualizarDesdeCantidad);
        inputMonto.addEventListener('input', actualizarDesdeMonto);

        function actualizarDesdeCantidad() {
            let cantidad = parseFloat(inputCantidad.value) || 0;
            if (cantidad < 0) cantidad = 0;
            
            let precioUnitario = parseFloat(unitPriceSpan.textContent.replace(',', '.')) || 0;
            let totalMostrado = parseFloat(totalAmountSpan.textContent.replace(',', '.')) || 0;
            
            let maxCantidad = totalMostrado / precioUnitario;
            if (cantidad > maxCantidad) {
                cantidad = maxCantidad;
                inputCantidad.value = cantidad.toFixed(2);
            }
            
            const monto = cantidad * precioUnitario;
            montoCalculadoSpan.textContent = formatearMonto(monto);
            paidAmountSpan.textContent = formatearMonto(monto);
            remainingSpan.textContent = formatearMonto(totalMostrado - monto);
            montoFinalInput.value = monto.toFixed(2);
        }

        function actualizarDesdeMonto() {
            let monto = parseFloat(inputMonto.value) || 0;
            if (monto < 0) monto = 0;
            
            let totalMostrado = parseFloat(totalAmountSpan.textContent.replace(',', '.')) || 0;
            if (monto > totalMostrado) {
                monto = totalMostrado;
                inputMonto.value = monto;
            }
            
            paidAmountSpan.textContent = formatearMonto(monto);
            remainingSpan.textContent = formatearMonto(totalMostrado - monto);
            montoFinalInput.value = monto.toFixed(2);
        }

        document.getElementById('partialPaymentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const montoFinal = parseFloat(montoFinalInput.value);
            if (!montoFinal || montoFinal <= 0) {
                alert('Debe ingresar un monto válido');
                return;
            }
            let totalMostrado = parseFloat(totalAmountSpan.textContent.replace(',', '.')) || 0;
            if (montoFinal > totalMostrado) {
                alert('El monto no puede superar el total de la cuenta');
                return;
            }
            const form = this;
            form.action = `/clientes/${currentClienteId}/cuentas/${currentCuentaId}/pago-parcial`;
            form.submit();
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closePartialPaymentModal();
        });
        modal.addEventListener('click', function(e) {
            if (e.target === modal) closePartialPaymentModal();
        });

        function adjustValue(delta) {
            const input = document.getElementById('inputBidones');
            let current = parseFloat(input.value) || 0;
            let newValue = current + delta;
            if (newValue >= 0 && newValue <= 999) {
                input.value = newValue.toFixed(2);
                const btnSave = document.querySelector('.btn-update-modern');
                const actual = <%= cliente.bidones_adeudados %>;
                if (Math.abs(newValue - actual) > 0.001) {
                    btnSave.style.background = 'var(--primary)';
                } else {
                    btnSave.style.background = 'var(--text-primary)';
                }
            }
        }

        function confirmarActualizacion() {
            const cantidad = document.getElementById('inputBidones').value;
            const actual = <%= cliente.bidones_adeudados %>;
            if (parseFloat(cantidad) === actual) {
                return;
            }
            if (confirm(`¿Confirmas que el cliente ahora tiene ${cantidad.replace('.', ',')} bidones?`)) {
                document.getElementById('formUpdateBidones').submit();
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const input = document.getElementById('inputBidones');
            if (input) {
                input.value = parseFloat(input.value).toFixed(2);
            }
        });

        const precioActual = <%= precioActual %>;
        const cantidadInput = document.getElementById('cantidad_bidones');
        const totalPrice = document.querySelector('.total-price');

        function actualizarTotal() {
            const cantidad = parseInt(cantidadInput.value) || 0;
            const total = cantidad * precioActual;
            totalPrice.textContent = `$${total.toFixed(2).replace('.', ',')}`;
        }
        if (cantidadInput) cantidadInput.addEventListener('input', actualizarTotal);
        actualizarTotal();

        function eliminarEstadoSemanal(id, estado) {
            if (confirm(`¿Eliminar registro de "${estado}"?`)) {
                fetch(`/clientes/estado-semanal/${id}`, {
                    method: 'DELETE'
                })
                .then(response => {
                    if (response.ok) {
                        location.reload();
                    } else {
                        alert('Error al eliminar');
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('Error');
                });
            }
        }

        function switchVentaTab(tab) {
            const tabs = document.querySelectorAll('.payment-tab');
            const contents = document.querySelectorAll('#venta-tab-cantidad, #venta-tab-monto');
            tabs.forEach(t => t.classList.remove('active'));
            contents.forEach(c => c.classList.remove('active'));
            if (tab === 'cantidad') {
                tabs[0].classList.add('active');
                document.getElementById('venta-tab-cantidad').classList.add('active');
                document.getElementById('cantidad_bidones').disabled = false;
                document.getElementById('monto').disabled = true;
                document.getElementById('monto').value = '';
                document.getElementById('gabriel-summary').style.display = 'none';
            } else {
                tabs[1].classList.add('active');
                document.getElementById('venta-tab-monto').classList.add('active');
                document.getElementById('monto').disabled = false;
                document.getElementById('cantidad_bidones').disabled = true;
                document.getElementById('cantidad_bidones').value = '';
                document.getElementById('gabriel-summary').style.display = 'block';
                const montoInput = document.getElementById('monto');
                const totalPrice = document.querySelector('#gabriel-summary .total-price');
                if (montoInput && totalPrice) {
                    montoInput.addEventListener('input', function() {
                        const val = parseFloat(this.value) || 0;
                        totalPrice.textContent = `$${val.toFixed(2).replace('.', ',')}`;
                    });
                }
            }
        }

        <% if (usuarioRol === 'gabriel') { %>
            document.addEventListener('DOMContentLoaded', function() {
                switchVentaTab('cantidad');
            });
        <% } %>
    </script>
</body>
</html>