<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clientes</title>
    <link rel="stylesheet" href="/public/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        /* Estilos adicionales para el modal (usando la misma paleta de colores) */
        .modal-editar {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            z-index: 1000;
            width: 90%;
            max-width: 450px;
            box-sizing: border-box;
            border: 1px solid #ddd;
        }

        .modal-editar h3 {
            margin-top: 0;
            margin-bottom: 20px;
            color: rgb(0, 0, 128);
            font-size: 1.5rem;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
        }

        .modal-editar label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
            color: #333;
        }

        .modal-editar input {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 16px;
            box-sizing: border-box;
            transition: border-color 0.3s;
        }

        .modal-editar input:focus {
            border-color: rgb(0, 0, 128);
            outline: none;
            box-shadow: 0 0 5px rgba(0, 0, 128, 0.3);
        }

        .modal-botones {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 10px;
        }

        .modal-botones button {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s, transform 0.1s;
        }

        .btn-guardar {
            background-color: rgb(0, 0, 128);
            color: white;
        }

        .btn-guardar:hover {
            background-color: #0000a0;
        }

        .btn-cancelar {
            background-color: #f44336;
            color: white;
        }

        .btn-cancelar:hover {
            background-color: #d32f2f;
        }

        #modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
        }

        /* Ajuste responsive para móviles */
        @media (max-width: 480px) {
            .modal-editar {
                padding: 20px;
                width: 95%;
            }
            .modal-botones {
                flex-direction: column;
                gap: 10px;
            }
            .modal-botones button {
                width: 100%;
            }
        }

        /* Mejora en la tarjeta para el menú de tres puntos */
        .cliente-card {
            position: relative;
        }
        .menu-options {
            position: absolute;
            top: 35px;
            right: 10px;
            background: white;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            z-index: 100;
            display: none;
            flex-direction: column;
            min-width: 120px;
        }
        .menu-options button {
            background: none;
            border: none;
            padding: 10px 15px;
            text-align: left;
            cursor: pointer;
            font-size: 14px;
            transition: background 0.2s;
        }
        .menu-options button:hover {
            background-color: #f0f0f0;
        }
        .menu-options button:first-child {
            border-bottom: 1px solid #eee;
        }

        /* Estilos para el paginador de días */
        .pagination-dias {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 10px;
            margin: 30px 0 20px;
        }
        .pagination-dias a {
            padding: 8px 16px;
            background: #f0f0f0;
            color: #333;
            text-decoration: none;
            border-radius: 20px;
            font-weight: 500;
            transition: all 0.3s;
            border: 1px solid #ddd;
        }
        .pagination-dias a.active {
            background: rgb(0, 0, 128);
            color: white;
            border-color: rgb(0, 0, 128);
        }
        .pagination-dias a:hover:not(.active) {
            background: #e0e0e0;
        }

        /* --- PAGINADOR NUMÉRICO REPARADO (RESPONSIVE) --- */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;          /* Permite que los números salten a la siguiente línea */
            gap: 8px;                 /* Espacio uniforme entre botones, en lugar de margin */
            margin: 20px 0;
        }
        .pagination a {
            text-decoration: none;
            color: #ffffff;
            background-color: #cfc1c1;
            padding: 8px 12px;        /* Un poco más pequeño que antes */
            border-radius: 5px;
            transition: background-color 0.3s ease;
            min-width: 36px;           /* Ancho mínimo para que sean consistentes */
            text-align: center;
        }
        .pagination a:hover {
            background-color: rgb(0, 0, 128);
            color: #fff;
        }
        .pagination a.active {
            background-color: rgb(0, 0, 128);
            font-weight: bold;
        }
        /* Ajuste para móviles muy pequeños */
        @media (max-width: 480px) {
            .pagination a {
                padding: 6px 10px;
                font-size: 14px;
                min-width: 32px;
            }
            /* También reducimos un poco los días si es necesario */
            .pagination-dias a {
                padding: 6px 12px;
                font-size: 14px;
            }
        }

        /* Nuevos estilos para bordes de estado */
        .cliente-card.border-green {
            border: 2px solid green;
        }
        .cliente-card.border-red {
            border: 2px solid red;
        }
        .cliente-card.border-gray {
            border: 2px solid gray;
        }

        /* Estilos para los íconos de estado semanal */
        .estado-semanal-icons {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 10px;
        }
        .estado-icon {
            font-size: 1.5rem;
            cursor: pointer;
            opacity: 0.5;
            transition: opacity 0.2s;
        }
        .estado-icon.active {
            opacity: 1;
        }
        .estado-icon[data-estado="compro"] { color: green; }
        .estado-icon[data-estado="no_compro"] { color: red; }
        .estado-icon[data-estado="no_estaba"] { color: gray; }
    </style>
</head>
<body>
    <header>
        <div class="menu-icon">
            <div class="menu-icon-bar"></div>
            <div class="menu-icon-bar"></div>
            <div class="menu-icon-bar"></div>
        </div>
        <nav class="nav-menu">                                               
            <a href="/home">Inicio</a>                                                                                                                                                                                                                                                             
            <a href="/historial/cuentas">historial</a>
            <a href="/notas">notas</a>
            <a href="/chat/grupal" class="chat-link">
                chat
                <% if (typeof usuarioId !== 'undefined' && usuarioId) { %>
                    <span class="badge-unread" id="chatBadge" style="display: none;">0</span>
                <% } %>
            </a>
                                <a href="/configuracion" class="admin-link">configuración</a>
            <% if (typeof usuarioRol !== 'undefined' && usuarioRol === 'admin') { %>            
                <a href="/admin/invitaciones" class="admin-link">Invitaciones</a>
            <% } %>                                                                                            
        </nav>                                                                                                                                                                      
        <div class="registroinicio">
            <% if (nombreUsuario) { %>
                <span><%= nombreUsuario %></span>
                <a href="/logout">Cerrar sesión</a>
            <% } else { %>
                <a href="/login">Iniciar sesión</a>
                <a href="/registro">Crear cuenta</a>
            <% } %>
        </div>
    </header>

    <main class="main-container">
        <% if (nombreUsuario) { %>
            <h1 class="main-title">Clientes</h1>
            <div class="search-container">
                <form action="/home" method="GET">
                    <input 
                        type="text" 
                        name="filtro"
                        class="search-input" 
                        placeholder="Buscar por nombre, dirección o teléfono" 
                        value="<%= filtro || '' %>" 
                    />
                    <button type="submit" class="search-button">
                        <i class="fas fa-search search-icon"></i>
                    </button>
                </form>
            </div>
    
            <% if (clientes && clientes.length) { %>
                <div class="clientes-container">
                    <% clientes.forEach(cliente => { 
                        // Determinar clase de borde según estado semanal actual
                        let borderClass = '';
                        if (usuarioRol === 'gabriel' && estadosSemanales && estadosSemanales[cliente.id]) {
                            if (estadosSemanales[cliente.id] === 'compro') borderClass = 'border-green';
                            else if (estadosSemanales[cliente.id] === 'no_compro') borderClass = 'border-red';
                            else if (estadosSemanales[cliente.id] === 'no_estaba') borderClass = 'border-gray';
                        }
                    %>
                        <div class="cliente-card <%= borderClass %>" data-id="<%= cliente.id %>" data-nombre="<%= cliente.nombre %>" data-direccion="<%= cliente.direccion %>" data-telefono="<%= cliente.telefono %>" id="cliente-<%= cliente.id %>">
                            <p>
                                <i class="fas fa-user"></i>  <%= cliente.nombre %>
                            </p>
                            
                            <p class="direccion">
                                <i class="fas fa-map-marker-alt"></i> 
                                <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(cliente.direccion) %>" 
                                   target="_blank" 
                                   title="Ver en Google Maps">
                                    <%= cliente.direccion %>
                                </a>
                            </p>

                            <p>
                                <i class="fas fa-phone-alt" style="color: green;"></i> 
                                <a href="tel:<%= cliente.telefono %>" style="text-decoration: none; color: inherit;">
                                    <%= cliente.telefono %>
                                </a>
                            </p>                                                       
    
                            <!-- CAMBIO: Añadimos ?dia=... para usuario gabriel -->
                            <a href="/clientes/<%= cliente.id %><%= usuarioRol === 'gabriel' ? '?dia=' + diaSeleccionado : '' %>" class="ver-detalle">Ver detalles</a>
                            
                            <!-- Botón de tres puntos y menú flotante -->
                            <button class="menu-cliente" onclick="toggleMenu(this)">&#x22EE;</button>
                            <div class="menu-options">
                                <button onclick="editarCliente(<%= cliente.id %>)">Editar</button>
                                <button onclick="eliminarCliente(<%= cliente.id %>)">Eliminar</button>
                            </div>

                            <%
                                let bidonesVal = Number(cliente.bidones_adeudados);
                                let bidonesMostrar = bidonesVal % 1 === 0 
                                    ? bidonesVal.toString() 
                                    : bidonesVal.toFixed(2).replace(/\.?0+$/, '').replace('.', ',');
                            %>
                            <p>Bidones adeudados: <%= bidonesMostrar %></p>
                            
                            <!-- Mostrar total fiado del día SOLO para usuario gabriel -->
                            <% if (usuarioRol === 'gabriel' && cliente.totalFiadoHoy !== undefined) { 
                                let totalFiado = Number(cliente.totalFiadoHoy);
                                let totalMostrar = totalFiado % 1 === 0 
                                    ? totalFiado.toString() 
                                    : totalFiado.toFixed(2).replace(/\.?0+$/, '').replace('.', ',');
                            %>
                                <p class="total-fiado-dia">
                                    <i class="fas fa-clock" style="color: #f39c12;"></i> 
                                    Fiado hoy: <strong>$<%= totalMostrar %></strong>
                                </p>
                            <% } %>

                            <!-- Íconos de estado semanal - Solo visible para gabriel -->
                            <% if (usuarioRol === 'gabriel') { %>
                            <div class="estado-semanal-icons">
                                <i class="fas fa-check-circle estado-icon <%= estadosSemanales && estadosSemanales[cliente.id] === 'compro' ? 'active' : '' %>" data-estado="compro" title="Compró"></i>
                                <i class="fas fa-times-circle estado-icon <%= estadosSemanales && estadosSemanales[cliente.id] === 'no_compro' ? 'active' : '' %>" data-estado="no_compro" title="No compró"></i>
                                <i class="fas fa-ban estado-icon <%= estadosSemanales && estadosSemanales[cliente.id] === 'no_estaba' ? 'active' : '' %>" data-estado="no_estaba" title="No estaba"></i>
                            </div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="no-clientes">No hay clientes registrados para este filtro.</p>
            <% } %>

            <!-- Paginador de días (para usuario gabriel) - SIEMPRE visible -->
            <% if (usuarioRol === 'gabriel') { %>
                <div class="pagination-dias">
                    <% const dias = ['lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado', 'domingo']; %>
                    <% dias.forEach(d => { %>
                        <a href="/home?dia=<%= d %>&filtro=<%= filtro || '' %>" 
                           class="<%= d === diaSeleccionado ? 'active' : '' %>">
                            <%= d.charAt(0).toUpperCase() + d.slice(1) %>
                        </a>
                    <% }); %>
                </div>
            <% } else { %>
                <!-- Paginador numérico (para otros roles) - AHORA RESPONSIVE -->
                <% if (totalPaginas > 0) { %>
                    <div class="pagination">
                        <% if (page > 1) { %>
                            <a href="/home?page=<%= page - 1 %>&filtro=<%= filtro %>" class="pagination-arrow"><</a>
                        <% } %>
                        <% for (let i = 1; i <= totalPaginas; i++) { %>                                                                        
                            <a href="/home?page=<%= i %>&filtro=<%= filtro %>" class="<%= i == page ? 'active' : '' %>"><%= i %></a>
                        <% } %>
                        <% if (page < totalPaginas) { %>
                            <a href="/home?page=<%= page + 1 %>&filtro=<%= filtro %>" class="pagination-arrow">></a>
                        <% } %>
                    </div>
                <% } %>
            <% } %>

        <% } else { %>
            <p class="no-sesion">Debes iniciar sesión para ver la lista de clientes.</p>
        <% } %>
    </main>
     
    <% if (nombreUsuario) { %>
        <div class="agregarcliente">
            <a href="/clientes">
                <i class="fas fa-plus"></i>
            </a>
        </div>
    <% } %>

    <!-- Modal para editar cliente -->
    <div id="modal-editar" class="modal-editar" style="display: none;">
        <h3>Editar Cliente</h3>
        <input type="hidden" id="edit-id">
        <label>Nombre:</label>
        <input type="text" id="edit-nombre" placeholder="Nombre completo">
        <label>Dirección:</label>
        <input type="text" id="edit-direccion" placeholder="Calle y número">
        <label>Teléfono:</label>
        <input type="text" id="edit-telefono" placeholder="Teléfono de contacto">
        <div class="modal-botones">
            <button class="btn-guardar" onclick="guardarEdicion()">Guardar</button>
            <button class="btn-cancelar" onclick="cerrarModal()">Cancelar</button>
        </div>
    </div>
    <div id="modal-overlay" style="display: none;" onclick="cerrarModal()"></div>

    <!-- Scripts -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const menuIcon = document.querySelector('.menu-icon');
        const navMenu = document.querySelector('.nav-menu');
        const mainContainer = document.querySelector('.main-container');

        menuIcon.addEventListener('click', () => {
            navMenu.classList.toggle('show');
            if (navMenu.classList.contains('show')) {
                mainContainer.style.marginTop = '300px';
            } else {
                mainContainer.style.marginTop = '0';
            }
        });

        function toggleMenu(button) {
            const menu = button.nextElementSibling;
            document.querySelectorAll('.menu-options').forEach(m => {
                if (m !== menu) m.style.display = 'none';
            });
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }

        function editarCliente(id) {
            const card = document.querySelector(`.cliente-card[data-id="${id}"]`);
            const nombre = card.dataset.nombre;
            const direccion = card.dataset.direccion;
            const telefono = card.dataset.telefono;

            document.getElementById('edit-id').value = id;
            document.getElementById('edit-nombre').value = nombre;
            document.getElementById('edit-direccion').value = direccion;
            document.getElementById('edit-telefono').value = telefono;

            document.getElementById('modal-editar').style.display = 'block';
            document.getElementById('modal-overlay').style.display = 'block';
            
            const menu = card.querySelector('.menu-options');
            if (menu) menu.style.display = 'none';
        }

        function cerrarModal() {
            document.getElementById('modal-editar').style.display = 'none';
            document.getElementById('modal-overlay').style.display = 'none';
        }

        function guardarEdicion() {
            const id = document.getElementById('edit-id').value;
            const nombre = document.getElementById('edit-nombre').value.trim();
            const direccion = document.getElementById('edit-direccion').value.trim();
            const telefono = document.getElementById('edit-telefono').value.trim();

            if (!nombre || !direccion || !telefono) {
                alert('Todos los campos son obligatorios');
                return;
            }

            fetch(`/clientes/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre, direccion, telefono })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const card = document.querySelector(`.cliente-card[data-id="${id}"]`);
                    if (card) {
                        card.dataset.nombre = nombre;
                        card.dataset.direccion = direccion;
                        card.dataset.telefono = telefono;
                        const nombreP = card.querySelector('p:first-child');
                        if (nombreP) nombreP.innerHTML = `<i class="fas fa-user"></i> ${nombre}`;
                        const direccionA = card.querySelector('.direccion a');
                        if (direccionA) {
                            direccionA.textContent = direccion;
                            direccionA.href = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(direccion)}`;
                        }
                        const telefonoA = card.querySelector('p:nth-child(3) a');
                        if (telefonoA) {
                            telefonoA.textContent = telefono;
                            telefonoA.href = `tel:${telefono}`;
                        }
                    }
                    cerrarModal();
                } else {
                    alert('Error al actualizar: ' + (data.error || 'Desconocido'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error al actualizar el cliente');
            });
        }

        function eliminarCliente(clienteId) {
            if (confirm("¿Estás seguro de que deseas eliminar este cliente?")) {
                fetch(`/clientes/${clienteId}`, { method: 'DELETE' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Error al eliminar el cliente');
                    });
            }
        }

        document.addEventListener('click', function(event) {
            if (!event.target.classList.contains('menu-cliente') && !event.target.closest('.menu-options')) {
                document.querySelectorAll('.menu-options').forEach(menu => {
                    menu.style.display = 'none';
                });
            }
        });

        <% if (typeof usuarioId !== 'undefined' && usuarioId) { %>
            const socket = io();
            const usuarioId = <%= usuarioId %>;

            async function actualizarBadgeHeader() {
                try {
                    const response = await fetch('/api/no-leidos');
                    const noLeidosMap = await response.json();
                    const total = Object.values(noLeidosMap).reduce((acc, val) => acc + val, 0);
                    const badge = document.getElementById('chatBadge');
                    if (total > 0) {
                        badge.textContent = total;
                        badge.style.display = 'inline';
                    } else {
                        badge.style.display = 'none';
                    }
                } catch (error) {
                    console.error('Error al obtener no leídos:', error);
                }
            }

            socket.on('update-unread', actualizarBadgeHeader);
            document.addEventListener('DOMContentLoaded', actualizarBadgeHeader);
        <% } %>

        // Nuevo: Manejo de clic en íconos de estado semanal (solo se ejecuta si existen)
        document.querySelectorAll('.estado-icon').forEach(icon => {
            icon.addEventListener('click', function(e) {
                e.stopPropagation();
                const card = this.closest('.cliente-card');
                const clienteId = card.dataset.id;
                const estado = this.dataset.estado;

                fetch(`/clientes/${clienteId}/estado-semanal`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ estado })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Actualizar borde
                        card.classList.remove('border-green', 'border-red', 'border-gray');
                        if (estado === 'compro') card.classList.add('border-green');
                        else if (estado === 'no_compro') card.classList.add('border-red');
                        else if (estado === 'no_estaba') card.classList.add('border-gray');

                        // Actualizar clase active en íconos
                        card.querySelectorAll('.estado-icon').forEach(ic => {
                            ic.classList.remove('active');
                        });
                        this.classList.add('active');
                    } else {
                        alert('Error al guardar estado');
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('Error');
                });
            });
        });
    </script>
</body>
</html>